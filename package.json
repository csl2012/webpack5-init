{
  "name": "webpack5-project",
  "version": "1.0.0",
  "description": "Webpack 5 project with multi-page and single-page configuration",
  "main": "index.js",
  "scripts": {
    "build:dev": "cross-env NODE_ENV=production webpack --config webpack.config.dev.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.prod.js",
    "start": "cross-env NODE_ENV=development webpack serve --config webpack.config.dev.js",
    "start:prod": "cross-env NODE_ENV=production webpack serve --config webpack.config.prod.js",
    "lint": "eslint src --ext .js,.ts",
    "lint:css": "stylelint 'src/**/*.{css,scss}'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky",
    "analyze": "webpack --config webpack.config.prod.js --profile --json > dist/stats.json && webpack-bundle-analyzer dist/stats.json"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less,sass}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "npx husky add .husky/commit-msg 'npx --no-stdio -- commitlint --edit \"$1\"'"
    }
  },
  "keywords": [
    "webpack",
    "webpack5",
    "multi-page",
    "single-page",
    "babel",
    "es6"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.14.5",
    "@babel/plugin-proposal-object-rest-spread": "^7.13.8",
    "@babel/plugin-proposal-optional-chaining": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/runtime-corejs3": "^7.24.0",
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^9.1.3",
    "compression-webpack-plugin": "^12.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.0.11",
    "less": "^4.2.0",
    "lint-staged": "^15.2.2",
    "mini-css-extract-plugin": "^2.8.1",
    "postcss": "^8.4.38",
    "postcss-loader": "^7.3.3",
    "postcss-preset-env": "^9.5.0",
    "prettier": "^3.2.5",
    "sass": "^1.72.0",
    "sass-loader": "^14.1.0",
    "style-loader": "^3.3.4",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "thread-loader": "^4.0.4",
    "webpack": "^5.91.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^5.10.0",
    "webpackbar": "^7.0.0"
  },
  "dependencies": {
    "core-js": "^3.36.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
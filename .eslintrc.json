{
  "extends": [
    "standard"
  ],
  "env": {
    "browser": true,
    "es2021": true
  },
  "rules": {
    "no-console": "off",
    "eqeqeq": [
      "error",
      "always"
    ],
    "no-unused-vars": [
      "error"
    ],
    "prefer-const": "error",
    "no-var": "error",
    "arrow-spacing": "error",
    "prefer-arrow-callback": "error",
    "prefer-template": "error",
    "template-curly-spacing": "error"
  }
}
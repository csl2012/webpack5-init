{
  "extends": [
    "standard",
    "plugin:compat/recommended"
  ],
  "plugins": [
    "compat",
    "builtin-compat"
  ],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "warn",
    "space-before-function-paren": "off",
    "comma-dangle": [
      "error",
      "always-multiline"
    ], // 允许多行对象/数组的尾随逗号
    "semi": [
      "error",
      "always"
    ],
    "quotes": [
      "error",
      "single"
    ],
    "eqeqeq": [
      "error",
      "always"
    ],
    "no-unused-vars": [
      "error"
    ],
    "prefer-const": "error",
    "no-var": "error",
    "arrow-spacing": "error",
    "prefer-arrow-callback": "error",
    "prefer-template": "error",
    "template-curly-spacing": "error"
  }
}